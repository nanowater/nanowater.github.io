---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getOrGenerateHeroImage } from '../../utils/heroGenerator';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const visiblePosts = allPosts.filter((post) => import.meta.env.DEV || !post.data.draft);
	
	// Extract all unique tags from visible posts
	const uniqueTags = [...new Set(visiblePosts.map((post) => post.data.tags || []).flat())];
	
	// Create paths for each tag
	return Promise.all(
		uniqueTags.map(async (tag) => {
			const rawFilteredPosts = visiblePosts
				.filter((post) => (post.data.tags || []).includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
			
			// Resolve heroImage for dynamic aurora generation
			const filteredPosts = await Promise.all(
				rawFilteredPosts.map(async (post) => {
					if (!post.data.heroImage) {
						const generatedImage = await getOrGenerateHeroImage(post.data.title);
						return {
							...post,
							data: {
								...post.data,
								heroImage: generatedImage as any,
								isGenerated: true,
							}
						};
					}
					return {
						...post,
						data: {
							...post.data,
							isGenerated: false,
						}
					};
				})
			);

			return {
				params: { tag },
				props: { posts: filteredPosts },
			};
		})
	);
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`#${tag} - ${SITE_TITLE}`} description={`${tag} 태그가 지정된 글 목록입니다.`} />
		<style>
			main {
				width: 960px;
			}
			.tag-title-container {
				margin-bottom: 3rem;
				text-align: center;
			}
			.tag-title {
				font-size: 2.5rem;
				color: var(--accent);
				margin-bottom: 0.5rem;
			}
			.back-link {
				font-size: 1rem;
				color: rgb(var(--gray-dark));
				text-decoration: none;
			}
			.back-link:hover {
				color: var(--accent);
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.date {
				margin: 0.5rem 0 0 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: var(--accent);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.card-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-top: 0.75rem;
				justify-content: flex-start;
			}
			.card-tag {
				background-color: rgba(62, 68, 82, 0.3);
				color: rgb(var(--gray-dark));
				border: 1px solid rgba(62, 68, 82, 0.7);
				padding: 0.2rem 0.6rem;
				border-radius: 50px;
				font-size: 0.75rem;
				font-weight: 500;
				transition: all 0.2s ease;
			}
			ul li a:hover .card-tag {
				border-color: rgba(97, 175, 239, 0.5); /* Muted --accent */
				color: var(--accent);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tag-title-container">
				<h2 class="tag-title">#{tag}</h2>
				<a href="/blog" class="back-link">← 모든 글 보기</a>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										post.data.isGenerated ? (
											<img width={720} height={360} src={post.data.heroImage} alt="" />
										) : (
											<Image width={720} height={360} src={post.data.heroImage} alt="" />
										)
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									{post.data.tags && post.data.tags.length > 0 && (
										<div class="card-tags">
											{post.data.tags.map((tag: string) => (
												<span class="card-tag">#{tag}</span>
											))}
										</div>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
